# ============================================
# Trading Autopilot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Kite Connect (Zerodha) ---
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_REDIRECT_URL=http://localhost:8000/api/kite/callback

# --- Grok AI (xAI) ---
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-3-mini-fast
GROK_BASE_URL=https://api.x.ai/v1

# --- App Settings ---
APP_SECRET_KEY=generate_a_random_secret_key_here
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# --- Trading Settings ---
TRADING_MODE=paper
PAPER_TRADING_CAPITAL=100000.0
MAX_RISK_PER_TRADE_PCT=2.0
MAX_POSITIONS=6
MAX_SINGLE_POSITION_PCT=10.0
MAX_SECTOR_CONCENTRATION_PCT=30.0
MAX_PORTFOLIO_BETA=1.3
DAILY_LOSS_LIMIT_PCT=2.0
WEEKLY_LOSS_LIMIT_PCT=5.0
MONTHLY_LOSS_LIMIT_PCT=10.0
TOTAL_DRAWDOWN_LIMIT_PCT=20.0

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./trading_autopilot.db
